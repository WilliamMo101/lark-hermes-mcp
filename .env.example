# ============================================
# Feishu/Lark MCP server - Environment template
# ============================================
# Copy this file to `.env` and fill in your own values:
#   cp .env.example .env
# `.env` is listed in .gitignore and will never be committed.

# --- Required: Feishu/Lark app credentials ---
# Get these from https://open.feishu.cn/app (mainland Feishu)
# or https://open.larksuite.com/app (overseas Lark).
# Create a custom app (自建应用), then open the
# "Credentials & Basic Info / 凭证与基础信息" page.
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Required: app domain ---
# Mainland Feishu  -> Feishu
# Overseas   Lark  -> Lark
LARK_DOMAIN=Feishu

# --- Required: enabled toolsets (comma-separated) ---
# Valid values: messaging, docs, bitable, calendar, other
# `other` is required if you want the OAuth tools
# (lark_oauth_*) and task tools to be exposed.
LARK_ENABLED_TOOLSETS=messaging,docs,bitable,calendar,other

# --- Optional: log level ---
# trace | debug | info | warn | error  (default: info)
LARK_LOG_LEVEL=info
