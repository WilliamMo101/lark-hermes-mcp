  "description": "Thin MCP server exposing Feishu/Lark OpenAPI capabilities to Hermes and other MCP agents, bridging @larksuite/openclaw-lark's native tools.",
  "type": "module",
  "main": "dist/server.js",
  "license": "MIT",
  "author": "WilliamMo101 <mo523378747@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WilliamMo101/lark-hermes-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/WilliamMo101/lark-hermes-mcp/issues"
  },
  "homepage": "https://github.com/WilliamMo101/lark-hermes-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "feishu",
    "lark",
    "hermes",
    "agent",
    "openapi",
    "openclaw"
  ],
  "scripts": {
